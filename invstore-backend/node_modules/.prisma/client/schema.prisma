generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  nombre       String
  cargo        String
  user         String   @unique
  passwordHash String
  role         Role     @default(worker)
  foto         String?
  telefono     String   @default("")
  rut          String   @default("")
  especialidad String   @default("")
  estado       Estado   @default(active)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  solicitudes  Solicitud[]
  evaluaciones Evaluacion[] @relation("EvaluadoUser")
  evaluadoPor  Evaluacion[] @relation("EvaluadorUser")
  notas        Nota[]
  bodegaLogs   BodegaLog[]
}

enum Role {
  admin
  worker
}

enum Estado {
  active
  pause
  leave
  off
}

model Item {
  id        Int      @id @default(autoincrement())
  nombre    String
  codigo    String   @unique
  categoria String
  spec      String   @default("")
  stock     Int      @default(0)
  precio    Int?
  threshold Int      @default(5)
  foto      String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  solicitudItems SolicitudItem[]
  historial      Historial[]
  bodegaLogs     BodegaLog[]
}

model Solicitud {
  id              Int             @id @default(autoincrement())
  userId          String
  proyecto        String
  plano           String
  ficha           String
  status          SolicitudStatus @default(pending)
  aprobadoPor     String?
  fechaResolucion DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user  User            @relation(fields: [userId], references: [id])
  items SolicitudItem[]
}

enum SolicitudStatus {
  pending
  approved
  rejected
}

model SolicitudItem {
  id             Int  @id @default(autoincrement())
  solicitudId    Int
  itemId         Int
  cantidad       Int
  precioSnapshot Int?

  solicitud Solicitud @relation(fields: [solicitudId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
}

model Historial {
  id          Int      @id @default(autoincrement())
  itemId      Int
  solicitudId Int
  userId      String
  cantidad    Int
  precio      Int?
  proyecto    String
  plano       String
  ficha       String
  createdAt   DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id])
}

model Evaluacion {
  id          Int      @id @default(autoincrement())
  evaluadoId  String
  evaluadorId String
  solicitudId Int?
  rating      Int
  comment     String   @default("")
  proyecto    String   @default("")
  createdAt   DateTime @default(now())

  evaluado  User @relation("EvaluadoUser", fields: [evaluadoId], references: [id])
  evaluador User @relation("EvaluadorUser", fields: [evaluadorId], references: [id])
}

model Nota {
  id        Int      @id @default(autoincrement())
  userId    String
  byId      String
  byNombre  String
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BodegaLog {
  id        Int      @id @default(autoincrement())
  itemId    Int
  userId    String
  cantidad  Int
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
